]

# ============================================
#  DEFAULT 5D BET SEQUENCE (၇ ကြိမ်)
# ============================================
DEFAULT_5D_SEQUENCE = [100, 300, 900, 2400, 7200, 15000, 30000]

# ============================================
#  GAME SETTINGS
# ============================================
game_settings = {
    "5d": {
        "enabled": True,
        "game_type": "5D1minute",
        "bet_type": "even",  # even, odd, big, small
