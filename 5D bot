        "sequence": DEFAULT_5D_SEQUENCE.copy()
    }
}

# ============================================
#  CKLOTTERY API
# ============================================
LOGIN_URL = "http://www.cklottery.org/api/login"
BET_URL = "http://www.cklottery.org/api/bet"
BALANCE_URL = "http://www.cklottery.org/api/balance"
RESULT_URL = "http://www.cklottery.org/api/result"

# ============================================
#  GLOBAL VARIABLES
# ============================================
session = requests.Session()
is_running = False
is_paused = False
total_win = 0
total_loss = 0
consecutive_losses = 0
chat_id = None
is_logged_in = False
last_result = None

# ============================================
#  AUTH CHECK
# ============================================
def is_authorized(user_id):
    return user_id in AUTHORIZED_USERS

# ============================================
#  CKLOTTERY FUNCTIONS
# ============================================

def login():
    global is_logged_in
    try:
        login_data = {"phone": PHONE, "password": PASSWORD}
        response = session.post(LOGIN_URL, data=login_data, timeout=10)
        if response.status_code == 200:
            is_logged_in = True
            return True
        is_logged_in = False
        return False
    except:
        is_logged_in = False
        return False

def get_balance():
    try:
        response = session.get(BALANCE_URL, timeout=10)
        if response.status_code == 200:
            return response.json().get("balance", 0)
        return 0
    except:
        return 0

def get_last_result():
    """နောက်ဆုံးပွဲရလဒ်ကိုယူမယ်"""
    try:
        response = session.get(RESULT_URL, timeout=10)
        if response.status_code == 200:
            data = response.json()
            return data.get("number", None)
        return None
    except:
        return None

def get_bet_type_from_number(number):
    """ဂဏန်းကိုကြည့်ပြီး Even/Odd ဆုံးဖြတ်မယ်"""
    if number is None:
        return None
    number = int(number)
    if number % 2 == 0:
        return "even"
    else:
        return "odd"

def place_bet(game_type, bet_type, amount):
    try:
        bet_data = {
            "game": game_type,
            "type": bet_type,
            "amount": amount
        }
        response = session.post(BET_URL, data=bet_data, timeout=10)
        if response.status_code == 200:
            return response.json()
        return {"status": "error"}
    except:
        return {"status": "error"}

