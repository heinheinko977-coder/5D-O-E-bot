async def set_5d_seq(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    if not is_authorized(user_id):
        await update.message.reply_text("⛔ ခွင့်မပြုပါ!")
        return
    try:
        args = context.args
        if args:
            new_seq = [int(x) for x in args[0].split(',')]
            if len(new_seq) != 7:
                await update.message.reply_text("❌ လိုက်ဆ ၇ လုံးအတိအကျထည့်ပါ။")
                return
            game_settings["5d"]["sequence"] = new_seq
            await update.message.reply_text(
                f"✅ 5D လိုက်ဆပြောင်းပြီး: `{new_seq}`\n"
                f"🔄 အိုင်/ကုန်ရင် `{new_seq[0]}` ကနေ ပြန်စမယ်",
                parse_mode="Markdown"
            )
        else:
            seq = game_settings["5d"]["sequence"]
            await update.message.reply_text(f"📈 5D လက်ရှိလိုက်ဆ: `{seq}`", parse_mode="Markdown")
    except:
        await update.message.reply_text(
            "❌ ပုံစံမှားပါတယ်။\n"
            "ဥပမာ: `/set5dseq 100,300,900,2400,7200,15000,30000`",
            parse_mode="Markdown"
        )

