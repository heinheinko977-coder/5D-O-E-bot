#  MAIN
# ============================================

def main():
    app = Application.builder().token(TOKEN).build()
    
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("set5dseq", set_5d_seq))
    app.add_handler(CallbackQueryHandler(button_handler))
    
    print("🤖 5D Bot is running on Railway...")
    print(f"📈 5D Sequence: {game_settings['5d']['sequence']}")
    print(f"🔁 Follow Mode: {game_settings['5d']['follow']}")
    
