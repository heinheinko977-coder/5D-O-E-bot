        )

# ============================================
#  5D AUTO BET LOOP
# ============================================

async def auto_bet_5d():
    global is_running, is_paused, total_win, total_loss, consecutive_losses, chat_id, last_result
    
    settings = game_settings["5d"]
    seq = settings["sequence"]
    game_type = settings["game_type"]
    bet_type = settings["bet_type"]
    follow = settings["follow"]
    
    first_bet = True
    
    while is_running:
        while is_paused and is_running:
            time.sleep(2)
            continue
        
        if not is_running:
            break
        
        # ===== လိုက်ဆကုန်ရင် ပြန်စမယ် =====
        if consecutive_losses >= len(seq):
            await context.bot.send_message(
                chat_id,
                f"🔄 **လိုက်ဆကုန်သွားပါပြီ!**\n"
                f"ပြန် `{seq[0]}` ကနေ စမယ်။",
                parse_mode="Markdown"
            )
            consecutive_losses = 0
            continue
        
        # ===== နောက်ဆုံးရလဒ်ကိုယူမယ် (ပထမအကြိမ်မဟုတ်ရင်) =====
        if not first_bet and follow:
            last_num = get_last_result()
            if last_num is not None:
                new_bet_type = get_bet_type_from_number(last_num)
                if new_bet_type:
                    bet_type = new_bet_type
                    await context.bot.send_message(
                        chat_id,
                        f"🔁 **လိုက်ထိုးမယ်!**\n"
                        f"နောက်ဆုံးကျတာက `{last_num}` → `{bet_type}` ကိုလိုက်ထိုးမယ်",
                        parse_mode="Markdown"
                    )
        
        first_bet = False
        
        # ===== လက်ကျန်စစ် =====
        bal = get_balance()
        bet_amount = seq[consecutive_losses]
        
        if bal < bet_amount:
            await context.bot.send_message(
                chat_id,
                f"⚠️ **လက်ကျန်မလောက်ပါ!**\n"
                f"လိုတယ်: `{bet_amount}`, ရှိတယ်: `{bal}`\n"
                f"Bot ရပ်ဆိုင်းလိုက်ပါပြီ။",
                parse_mode="Markdown"
            )
            is_running = False
            break
        
        # ===== ထီးထိုး =====
        await context.bot.send_message(
            chat_id,
            f"🎯 **ထိုးနေပါပြီ...**\n"
            f"📌 ထိုးပုံစံ: `{bet_type}`\n"
            f"💰 ထိုးငွေ: `{bet_amount}`",
            parse_mode="Markdown"
        )
        
        result = place_bet(game_type, bet_type, bet_amount)
        
        # ===== ရလဒ်စစ် =====
        if result.get("status") == "win":
            total_win += bet_amount
            await context.bot.send_message(
                chat_id,
                f"🎉 **5D အိုင်!**\n"
                f"💰 ထိုးငွေ: `{bet_amount}`\n"
                f"🏆 စုစုပေါင်းအိုင်: `{total_win}`\n"
                f"🔄 ပြန် `{seq[0]}` ကနေ စမယ်",
                parse_mode="Markdown"
            )
            consecutive_losses = 0  # အိုင်ရင် ပြန်စ
        else:
            total_loss += bet_amount
            consecutive_losses += 1
            next_bet = seq[consecutive_losses] if consecutive_losses < len(seq) else seq[0]
            await context.bot.send_message(
                chat_id,
                f"😞 **5D ရှုံး!**\n"
                f"💰 ထိုးငွေ: `{bet_amount}`\n"
                f"❌ စုစုပေါင်းရှုံး: `{total_loss}`\n"
                f"📉 အရှုံးဆက်: `{consecutive_losses}/{len(seq)}`\n"
                f"📈 နောက်ထိုးငွေ: `{next_bet}`",
                parse_mode="Markdown"
            )
        
        # ===== စောင့်ချိန် (5D က ၁ မိနစ်) =====
        time.sleep(60)

